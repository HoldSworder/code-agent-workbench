{
  "name": "@code-agent/sidecar",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --target node20 --no-splitting --external better-sqlite3 && cp -r tools dist/tools",
    "build:sea": "bash scripts/build-sea.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@blowmage/cursor-agent-acp": "^0.7.1",
    "better-sqlite3": "^12.8.0",
    "undici": "^8.0.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
